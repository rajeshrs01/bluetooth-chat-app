{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Create virtual environment",
      "type": "shell",
      "command": "python -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
      "windows": {
        "command": "python -m venv venv && venv\\Scripts\\activate && pip install -r requirements.txt"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "pytest tests/ -v --tb=short",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run tests with coverage",
      "type": "shell",
      "command": "pytest tests/ -v --cov=src --cov-report=term-missing",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint (flake8)",
      "type": "shell",
      "command": "flake8 src/ tests/ --max-line-length=100",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Format code (black)",
      "type": "shell",
      "command": "black src/ tests/ --line-length 100",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: new feature branch",
      "type": "shell",
      "command": "git checkout develop && git pull origin develop && git checkout -b feature/${input:branchName}",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: push current branch",
      "type": "shell",
      "command": "git push origin $(git branch --show-current)",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "branchName",
      "description": "Feature branch name (e.g. gui-interface)",
      "default": "my-feature",
      "type": "promptString"
    }
  ]
}
